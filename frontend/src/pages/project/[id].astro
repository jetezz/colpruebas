---
export const prerender = false;

interface ProjectParams {
  id: string;
}

const { id } = Astro.params as ProjectParams;
const url = new URL(Astro.request.url);
const tab = url.searchParams.get('tab') ?? 'test';
const projectId = id ?? '511a017a-01d4-4553-a063-ba01438b15cd';

const bundlePath = 'docs/app-map/views/project-workspace/features/test-tab.md';
const environment = import.meta.env.PUBLIC_ENVIRONMENT ?? 'production';
const apiBase = (import.meta.env as Record<string, string | undefined>).PUBLIC_API_URL ?? '';
---
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{`Test Tab · ${projectId}`}</title>
    <style>
      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      body {
        font-family: system-ui, -apple-system, sans-serif;
        background: #f3f4f6;
        min-height: 100vh;
        padding: 24px;
        color: #111827;
      }
      .shell {
        max-width: 1100px;
        margin: 0 auto;
      }
      .shell-header {
        background: white;
        padding: 1.25rem 1.5rem;
        border-radius: 8px 8px 0 0;
        border: 1px solid #e5e7eb;
        border-bottom: none;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
      }
      .shell-header h1 {
        font-size: 1rem;
        color: #374151;
      }
      .shell-header code {
        font-family: ui-monospace, monospace;
        background: #f3f4f6;
        padding: 0.125rem 0.375rem;
        border-radius: 4px;
        font-size: 0.8125rem;
      }
      .shell-body {
        background: #f3f4f6;
        padding: 0 0 1rem 0;
      }
      .env {
        font-size: 0.75rem;
        color: #6b7280;
      }
      .pill {
        display: inline-block;
        padding: 0.25rem 0.625rem;
        background: #dbeafe;
        color: #1d4ed8;
        border-radius: 999px;
        font-size: 0.75rem;
        font-weight: 600;
      }
      .info-banner {
        background: #ecfdf5;
        color: #065f46;
        padding: 0.5rem 0.75rem;
        border: 1px solid #a7f3d0;
        border-radius: 8px;
        margin-bottom: 0.75rem;
        font-size: 0.8125rem;
      }
      .placeholder {
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        padding: 1.25rem 1.5rem;
        font-size: 0.875rem;
        color: #4b5563;
      }
      .placeholder code {
        background: #f3f4f6;
        padding: 0.125rem 0.375rem;
        border-radius: 4px;
      }
    </style>
  </head>
  <body>
    <div class="shell" data-testid="project-shell-root" data-project-id={projectId} data-bundle-path={bundlePath}>
      <header class="shell-header">
        <div>
          <h1>Project Workspace</h1>
          <code data-testid="project-shell-id">{projectId}</code>
        </div>
        <div>
          <span class="pill" data-testid="project-shell-tab-pill">{tab}</span>
          <span class="env">{environment}</span>
        </div>
      </header>
      <div class="shell-body">
        <nav
          aria-label="Tabs del workspace"
          data-testid="project-shell-tabs"
          class="project-tabs"
        >
          <ul>
            <li><span class="tab disabled">Comandos</span></li>
            <li><span class="tab disabled">Skills</span></li>
            <li><span class="tab disabled">Agentes</span></li>
            <li><span class="tab disabled">Programados</span></li>
            <li><span class="tab disabled">Entornos</span></li>
            <li><span class="tab disabled">Preview</span></li>
            <li>
              <a
                href={`/project/${projectId}?tab=test`}
                class={`tab ${tab === 'test' ? 'active' : ''}`}
                aria-current={tab === 'test' ? 'page' : undefined}
                data-testid="project-tab-link-test"
              >
                Test
              </a>
            </li>
          </ul>
        </nav>

        {tab === 'test' ? (
          <>
            <div class="info-banner" data-testid="project-shell-info">
              Este bundle es la única fuente funcional de criterios
              (<code>docs/app-map/views/project-workspace/features/test-tab.md</code>).
              Backend lee y escribe el bundle con SHA-256 pre/post + tmp +
              renameSync.
            </div>
            <div data-testid="test-tab-root" id="test-tab-root">
              <p>Cargando…</p>
            </div>
          </>
        ) : (
          <div class="placeholder" data-testid="project-shell-info">
            La tab <code>{tab}</code> no está disponible en este managed
            project. Usa <code>?tab=test</code> para acceder a la tab
            funcional de testing.
          </div>
        )}
      </div>
    </div>

    <script is:inline define:vars={{ projectId, bundlePath, apiBase }}>
      (async () => {
        const root = document.getElementById('test-tab-root');
        if (!root) return;

        async function api(url, opts) {
          const target = apiBase ? apiBase.replace(/\/$/, '') + url : url;
          const resp = await fetch(target, {
            headers: { 'Content-Type': 'application/json' },
            ...opts,
          });
          const body = await resp.json().catch(() => ({}));
          return { status: resp.status, body };
        }

        const { body: bundleBody } = await api(
          `/api/projects/${projectId}/docs/app-map?bundle=${encodeURIComponent(bundlePath)}`,
        );
        if (!bundleBody || !bundleBody.ok) {
          root.innerHTML = `<div class="error-banner">Error cargando bundle: ${(bundleBody && bundleBody.error) || 'network'}</div>`;
          return;
        }
        const { body: invBody } = await api(
          `/api/projects/${projectId}/test-inventory`,
        );
        const inv = (invBody && invBody.criteria) || {};

        const LEGEND = [
          ['passed', 'green', 'Cubierto', 'El test existe y pasó la última corrida.'],
          ['manual-evidence', 'blue', 'Evidencia', 'Evidencia PW-CLI o Manual registrada.'],
          ['partial', 'amber', 'Parcial', 'Cobertura parcial; revisar manualmente.'],
          ['not-run', 'red', 'Pendiente', 'El test existe pero no se ha corrido.'],
          ['failed', 'red', 'Falló', 'La última corrida del test falló.'],
          ['manual-missing', 'gray', 'Sin evidencia', 'PW-CLI o Manual sin evidencia registrada.'],
          ['no-test', 'gray', 'Sin test', 'No existe archivo de test o spec para el criterio.'],
          ['not-applicable', 'gray', 'No aplica', 'El método no aplica para este criterio.'],
        ];
        const METHODS = ['Unit', 'PW-CLI', 'PW-AUTO', 'Manual'];

        function resolve(method, coverage, invEntry) {
          const i = invEntry || {};
          if (method === 'Unit' || method === 'PW-AUTO') {
            const hasTest = method === 'Unit' ? i.hasUnitTest : i.hasPwautoSpec;
            if (!hasTest)
              return {
                state: 'no-test',
                color: 'gray',
                label: method === 'Unit' ? 'Sin test unit' : 'Sin PW-AUTO',
              };
            if (coverage === 'not-applicable')
              return { state: 'not-applicable', color: 'gray', label: 'No aplica' };
            if (coverage === 'covered')
              return { state: 'passed', color: 'green', label: 'Cubierto' };
            if (coverage === 'partial')
              return { state: 'partial', color: 'amber', label: 'Parcial' };
            return { state: 'not-run', color: 'red', label: 'Pendiente' };
          }
          if (method === 'PW-CLI') {
            if (coverage === 'covered')
              return { state: 'manual-evidence', color: 'blue', label: 'Evidencia PW-CLI' };
            if (coverage === 'not-applicable')
              return { state: 'not-applicable', color: 'gray', label: 'No aplica' };
            if (coverage === 'partial')
              return { state: 'partial', color: 'amber', label: 'Parcial PW-CLI' };
            return { state: 'manual-missing', color: 'gray', label: 'Sin evidencia PW-CLI' };
          }
          if (method === 'Manual') {
            if (coverage === 'covered')
              return { state: 'manual-evidence', color: 'green', label: 'Evidencia' };
            if (coverage === 'not-applicable')
              return { state: 'not-applicable', color: 'gray', label: 'No aplica' };
            return { state: 'manual-missing', color: 'gray', label: 'Sin evidencia' };
          }
          return { state: 'no-test', color: 'gray', label: 'Sin test' };
        }

        function escapeHtml(s) {
          return String(s || '').replace(/[&<>"']/g, (c) => ({
            '&': '&amp;',
            '<': '&lt;',
            '>': '&gt;',
            '"': '&quot;',
            "'": '&#39;',
          })[c]);
        }

        function renderChip(criterionId, method, result) {
          return `<span class="chip chip-${result.color}" data-testid="test-tab-quickrun-criterion-${criterionId}-${method}" data-method="${method}" data-state="${result.state}" data-color="${result.color}" title="${escapeHtml(result.label)}"><span class="chip-method">${method}</span><span class="chip-label">${escapeHtml(result.label)}</span></span>`;
        }

        function renderRow(c) {
          const chips = METHODS.map((m) => {
            const r = resolve(m, c.coverage?.[m], inv[c.id]);
            return renderChip(c.id, m, r);
          }).join('');
          return `<li class="criterion-row" data-testid="test-tab-quickrun-criterion-${c.id}" data-criterion-id="${c.id}">
            <div class="criterion-info">
              <span class="criterion-id">${escapeHtml(c.id)}</span>
              <span class="criterion-title">${escapeHtml(c.title || '')}</span>
            </div>
            <div class="chips">${chips}</div>
            <div class="actions">
              <button type="button" class="btn btn-ghost" data-testid="test-tab-validate-pwcli-${c.id}" data-action="pwcli" data-criterion-id="${c.id}">PW-CLI</button>
              <button type="button" class="btn btn-secondary" data-testid="test-tab-criterion-${c.id}-manual-mark" data-action="open-manual-modal" data-criterion-id="${c.id}">Manual</button>
            </div>
          </li>`;
        }

        const criteria = bundleBody.criteria || [];
        const totalCovered = criteria.filter((x) => x.coverage && x.coverage['Manual'] === 'covered').length;
        const totalPwcli = criteria.filter((x) => x.coverage && x.coverage['PW-CLI'] === 'covered').length;

        root.innerHTML = `
          <section data-testid="test-tab-section-config" class="test-tab-section">
            <h3>5.1 Dashboard de configuración</h3>
            <p class="hint">Formulario persistido por proyecto (placeholder). Toggle <code>has_auth</code>, URLs target, paths de unit/pwauto.</p>
            <div class="config-grid">
              <label><span>Entorno target</span><select disabled><option>Development</option></select></label>
              <label><span>URL target</span><input type="text" value="http://localhost:4323/project/${projectId}?tab=test" readonly /></label>
            </div>
          </section>
          <section data-testid="test-tab-section-quickrun" class="test-tab-section">
            <div class="quickrun-header">
              <h3>5.2 Sistema de testeo rápido</h3>
              <button type="button" class="btn btn-danger" data-testid="test-tab-quickrun-reset-coverage" data-action="open-reset-modal">Reset coverage</button>
            </div>
            <div class="summary-row" data-testid="test-tab-quickrun-summary">
              <span class="summary-stat"><strong data-testid="test-tab-quickrun-summary-total">${criteria.length}</strong> criterios</span>
              <span class="summary-stat"><strong data-testid="test-tab-quickrun-summary-manual-covered">${totalCovered}</strong> Manual OK</span>
              <span class="summary-stat"><strong data-testid="test-tab-quickrun-summary-pwcli-covered">${totalPwcli}</strong> PW-CLI OK</span>
            </div>
            <div class="legend" data-testid="test-tab-quickrun-legend" aria-label="Leyenda de estados">
              ${LEGEND.map((l) => `<span class="legend-item legend-${l[1]}"><span class="legend-dot legend-dot-${l[1]}" data-state="${l[0]}"></span><span class="legend-label">${l[2]}</span><span class="legend-desc">${l[3]}</span></span>`).join('')}
            </div>
            <ul class="criteria-list" data-testid="test-tab-quickrun-criteria-list">${criteria.map(renderRow).join('')}</ul>
          </section>
          <section data-testid="test-tab-section-scheduled" class="test-tab-section">
            <h3>5.3 Tareas programadas de test</h3>
            <p class="hint">Scheduler real no está dentro del scope de este managed project. El bundle declara el contrato TST-07 para futuras extensiones.</p>
          </section>

          <div class="modal" data-testid="test-tab-quickrun-reset-coverage-modal" hidden>
            <div class="modal-card">
              <h4>Resetear cobertura</h4>
              <p>Esto pondrá TODOS los criterios como <strong>Pendiente</strong> o <strong>Sin test</strong> según corresponda (los métodos con test definido vuelven a Pendiente y los métodos sin test definido vuelven a Sin test). Podrás volver a lanzarlos desde 5.2 para comprobar que se cubren de nuevo.</p>
              <div class="modal-actions">
                <button type="button" class="btn btn-ghost" data-testid="test-tab-quickrun-reset-cancel" data-action="close-reset-modal">Cancelar</button>
                <button type="button" class="btn btn-danger" data-testid="test-tab-quickrun-reset-confirm" data-action="reset-confirm">Resetear cobertura</button>
              </div>
              <div class="modal-result" data-testid="test-tab-quickrun-reset-result" hidden></div>
            </div>
          </div>

          <div class="modal" data-testid="test-tab-pwcli-fallback" hidden>
            <div class="modal-card">
              <h4>Agente PW-CLI no disponible</h4>
              <p>El endpoint devolvió <code>503 agent_unavailable</code>. Copia el prompt estructurado para validación manual o reintento posterior.</p>
              <pre class="pwcli-prompt" data-testid="test-tab-pwcli-fallback-prompt"></pre>
              <div class="modal-actions">
                <button type="button" class="btn btn-ghost" data-action="close-pwcli-fallback" data-testid="test-tab-pwcli-fallback-close">Cerrar</button>
                <button type="button" class="btn btn-secondary" data-action="copy-pwcli-prompt" data-testid="test-tab-pwcli-fallback-copy">Copiar prompt</button>
              </div>
              <div class="modal-result" data-testid="test-tab-pwcli-fallback-result" hidden></div>
            </div>
          </div>

          <div class="modal" data-testid="test-tab-quickrun-pwcli-result-modal" hidden>
            <div class="modal-card">
              <h4>Resultado PW-CLI</h4>
              <pre data-testid="test-tab-quickrun-pwcli-result-body"></pre>
              <div class="modal-actions">
                <button type="button" class="btn btn-secondary" data-action="close-pwcli-result" data-testid="test-tab-quickrun-pwcli-result-close">Cerrar</button>
              </div>
            </div>
          </div>
        `;

        function openModal(id) {
          const el = document.querySelector(`[data-testid="${id}"]`);
          if (el) el.hidden = false;
        }
        function closeModal(id) {
          const el = document.querySelector(`[data-testid="${id}"]`);
          if (el) el.hidden = true;
        }

        document.querySelectorAll('[data-action="open-reset-modal"]').forEach((b) =>
          b.addEventListener('click', () => openModal('test-tab-quickrun-reset-coverage-modal')),
        );
        document.querySelectorAll('[data-action="close-reset-modal"]').forEach((b) =>
          b.addEventListener('click', () => {
            closeModal('test-tab-quickrun-reset-coverage-modal');
            const r = document.querySelector('[data-testid="test-tab-quickrun-reset-result"]');
            if (r) { r.hidden = true; r.textContent = ''; }
          }),
        );
        document.querySelectorAll('[data-action="reset-confirm"]').forEach((b) =>
          b.addEventListener('click', async (ev) => {
            ev.target.disabled = true;
            const r = document.querySelector('[data-testid="test-tab-quickrun-reset-result"]');
            if (r) { r.hidden = false; r.textContent = 'Reset en curso...'; }
            const { body } = await api(`/api/projects/${projectId}/docs/app-map/coverage/reset`, {
              method: 'POST',
              body: JSON.stringify({ bundlePath }),
            });
            ev.target.disabled = false;
            if (r) { r.textContent = JSON.stringify(body, null, 2); }
            setTimeout(() => window.location.reload(), 800);
          }),
        );

        document.querySelectorAll('[data-action="open-manual-modal"]').forEach((b) =>
          b.addEventListener('click', () => {
            const criterionId = b.getAttribute('data-criterion-id');
            let d = document.querySelector(`[data-testid="test-tab-criterion-manual-affirm-${criterionId}"]`);
            if (!d) {
              d = document.createElement('dialog');
              d.dataset.testid = `test-tab-criterion-manual-affirm-${criterionId}`;
              d.className = 'criterion-manual-dialog';
              d.innerHTML = `<form method="dialog" class="criterion-manual-form">
                <h4>Marcar Manual OK — ${criterionId}</h4>
                <p>Esta acción marca exactamente el criterio ${criterionId} como <strong>Manual: covered</strong> en el bundle. Granularidad 1 criterio = 1 acción.</p>
                <div class="modal-actions">
                  <button value="cancel" class="btn btn-ghost" type="submit" data-testid="test-tab-criterion-manual-affirm-${criterionId}-cancel">Cancelar</button>
                  <button value="confirm" class="btn btn-secondary" type="submit" data-testid="test-tab-criterion-manual-affirm-${criterionId}-confirm">Confirmar</button>
                </div>
              </form>`;
              d.addEventListener('close', async () => {
                if (d.returnValue === 'confirm') {
                  const { body } = await api(`/api/projects/${projectId}/docs/app-map/coverage/manual`, {
                    method: 'POST',
                    body: JSON.stringify({ criterionId, bundlePath }),
                  });
                  if (body && body.ok) {
                    window.location.reload();
                  } else {
                    alert('Error al marcar Manual: ' + (body?.error || JSON.stringify(body)));
                  }
                }
              });
              document.body.appendChild(d);
            }
            d.showModal();
          }),
        );

        document.querySelectorAll('[data-action="pwcli"]').forEach((b) =>
          b.addEventListener('click', async () => {
            const criterionId = b.getAttribute('data-criterion-id');
            b.disabled = true;
            const { status, body } = await api(`/api/projects/${projectId}/test-pwcli/run`, {
              method: 'POST',
              body: JSON.stringify({ criterionId, bundlePath }),
            });
            b.disabled = false;
            if (status === 503 || body?.error === 'agent_unavailable') {
              const promptEl = document.querySelector('[data-testid="test-tab-pwcli-fallback-prompt"]');
              if (promptEl && body.prompt) promptEl.textContent = body.prompt;
              openModal('test-tab-pwcli-fallback');
              return;
            }
            const resultBody = document.querySelector('[data-testid="test-tab-quickrun-pwcli-result-body"]');
            if (resultBody) resultBody.textContent = JSON.stringify(body, null, 2);
            openModal('test-tab-quickrun-pwcli-result-modal');
            if (body?.ok) setTimeout(() => window.location.reload(), 1200);
          }),
        );

        document.querySelectorAll('[data-action="close-pwcli-result"]').forEach((b) =>
          b.addEventListener('click', () => closeModal('test-tab-quickrun-pwcli-result-modal')),
        );
        document.querySelectorAll('[data-action="close-pwcli-fallback"]').forEach((b) =>
          b.addEventListener('click', () => closeModal('test-tab-pwcli-fallback')),
        );
        document.querySelectorAll('[data-action="copy-pwcli-prompt"]').forEach((b) =>
          b.addEventListener('click', async () => {
            const promptEl = document.querySelector('[data-testid="test-tab-pwcli-fallback-prompt"]');
            const text = promptEl ? promptEl.textContent || '' : '';
            const r = document.querySelector('[data-testid="test-tab-pwcli-fallback-result"]');
            try {
              if (navigator.clipboard && navigator.clipboard.writeText) {
                await navigator.clipboard.writeText(text);
              } else {
                const ta = document.createElement('textarea');
                ta.value = text;
                document.body.appendChild(ta);
                ta.select();
                document.execCommand('copy');
                document.body.removeChild(ta);
              }
              if (r) { r.hidden = false; r.textContent = 'Prompt copiado al portapapeles.'; }
            } catch (err) {
              if (r) { r.hidden = false; r.textContent = 'No se pudo copiar: ' + (err?.message || String(err)); }
            }
          }),
        );
      })();
    </script>

    <link rel="stylesheet" href="/styles/test-tab.css" />

    <style is:global>
      .test-tab-section {
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        padding: 1rem 1.25rem;
        margin-top: 1rem;
      }
      .test-tab-section h3 {
        margin-top: 0;
        margin-bottom: 0.5rem;
        color: #111827;
        font-size: 1rem;
      }
      .test-tab-section .hint {
        color: #6b7280;
        font-size: 0.875rem;
        margin: 0 0 0.75rem 0;
      }
      .config-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 0.75rem;
      }
      .config-grid label {
        display: flex;
        flex-direction: column;
        font-size: 0.875rem;
        gap: 0.25rem;
      }
      .config-grid input,
      .config-grid select {
        padding: 0.5rem;
        border: 1px solid #d1d5db;
        border-radius: 6px;
        font-size: 0.875rem;
      }
      .quickrun-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 0.75rem;
      }
      .quickrun-header h3 {
        margin: 0;
        flex: 1;
      }
      .summary-row {
        display: flex;
        gap: 1rem;
        margin-bottom: 0.75rem;
        padding: 0.5rem 0.75rem;
        background: #f3f4f6;
        border-radius: 6px;
        font-size: 0.875rem;
      }
      .summary-row .summary-stat strong {
        color: #2563eb;
        font-size: 1.125rem;
        margin-right: 0.25rem;
      }
      .legend {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 0.5rem;
        margin: 0 0 1rem 0;
        padding: 0.75rem;
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        border-radius: 6px;
      }
      .legend-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.8125rem;
      }
      .legend-dot {
        display: inline-block;
        width: 12px;
        height: 12px;
        border-radius: 50%;
        border: 1px solid rgba(0, 0, 0, 0.1);
      }
      .legend-dot-green { background: rgba(34, 197, 94, 0.85); }
      .legend-dot-red { background: rgba(239, 68, 68, 0.85); }
      .legend-dot-amber { background: rgba(245, 158, 11, 0.85); }
      .legend-dot-gray { background: rgba(107, 114, 128, 0.5); }
      .legend-dot-blue { background: rgba(59, 130, 246, 0.85); }
      .legend-label {
        font-weight: 600;
        color: #374151;
      }
      .legend-desc {
        color: #6b7280;
        font-size: 0.75rem;
      }
      .criteria-list {
        list-style: none;
        padding: 0;
        margin: 0;
      }
      .criterion-row {
        display: grid;
        grid-template-columns: minmax(0, 2fr) minmax(0, 3fr) auto;
        gap: 0.75rem;
        align-items: center;
        padding: 0.625rem 0.75rem;
        border-bottom: 1px solid #f3f4f6;
      }
      .criterion-row:last-child {
        border-bottom: none;
      }
      .criterion-info {
        display: flex;
        flex-direction: column;
        gap: 0.125rem;
        overflow: hidden;
      }
      .criterion-id {
        font-family: ui-monospace, SFMono-Regular, monospace;
