---
import Header from '../components/Header.astro';
import InfoCard from '../components/InfoCard.astro';
import Footer from '../components/Footer.astro';

const appName = 'colpruebas';
const environment = import.meta.env.PUBLIC_ENVIRONMENT || 'test';
const timestamp = new Date().toISOString();

const frontendStatus = environment === 'production' 
  ? 'Estamos en el frontend de PRODUCCIÓN' 
  : 'Estamos en el frontend de TEST';

const apiStatus = environment === 'production'
  ? 'API de producción funcionando'
  : 'API de test funcionando';

const gitBranch = 'MAIN';
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{appName}</title>
    <style>
      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      body {
        font-family: system-ui, -apple-system, sans-serif;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 20px;
      }
      .container {
        background: white;
        padding: 2rem;
        border-radius: 16px;
        box-shadow: 0 20px 60px rgba(0,0,0,0.3);
        max-width: 600px;
        width: 100%;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <Header title={appName} />
      <InfoCard 
        appName={appName}
        environment={environment}
        frontendStatus={frontendStatus}
        apiStatus={apiStatus}
        gitBranch={gitBranch}
      />
      <Footer timestamp={timestamp} />
    </div>
  </body>
</html>
